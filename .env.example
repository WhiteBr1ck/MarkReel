# Public URLs
WEB_BASE_URL=http://localhost:5090
API_BASE_URL=http://localhost:4000

# Web -> API (Next.js proxy rewrite target)
INTERNAL_API_BASE_URL=http://api:4000

# Storage backend
# - sqlite: local persistent Prisma database
# - inmemory: dev only, volatile
MARKREEL_STORE=sqlite

# Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_AUTH_INSTANCE_ID=markreel-local-dev

# First admin account for self-hosted instances
MARKREEL_ADMIN_USERNAME=admin
MARKREEL_ADMIN_PASSWORD=adminpass123
MARKREEL_ADMIN_DISPLAY_NAME=管理员
MARKREEL_ALLOW_PUBLIC_REGISTRATION=false

# Database
DATABASE_URL=file:/app/data/markreel.db

# Redis
REDIS_URL=redis://redis:6379

# S3 (MinIO)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=markreel
S3_SECRET_KEY=markreel_secret
S3_BUCKET_ORIGINAL=markreel-original
S3_BUCKET_DERIVED=markreel-derived
S3_BUCKET_ATTACHMENTS=markreel-attachments

# Media processing
FFMPEG_THREADS=2
HLS_SEGMENT_SECONDS=4
