# Public URL
WEB_BASE_URL=http://localhost:5090
API_BASE_URL=http://localhost:4000

# First admin account
MARKREEL_ADMIN_USERNAME=admin
MARKREEL_ADMIN_PASSWORD=adminadmin
MARKREEL_ADMIN_DISPLAY_NAME=管理员

# Auth secrets. Change these before exposing the service outside your machine.
JWT_ACCESS_SECRET=markreel_default_access_secret_change_me
JWT_REFRESH_SECRET=markreel_default_refresh_secret_change_me

# Optional: allow users to register themselves.
MARKREEL_ALLOW_PUBLIC_REGISTRATION=false

# Optional: force a public MinIO endpoint. Leave empty for automatic detection and API fallback.
S3_PUBLIC_ENDPOINT=

# Optional: media processing defaults.
FFMPEG_THREADS=2
HLS_SEGMENT_SECONDS=4
