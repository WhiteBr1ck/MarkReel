# Public URLs
WEB_BASE_URL=http://localhost:5090
API_BASE_URL=http://localhost:4000

# Web -> API (Next.js proxy rewrite target)
INTERNAL_API_BASE_URL=http://api:4000

# Storage backend
# - inmemory: dev only, volatile (no Postgres required)
# - prisma: requires Postgres + DATABASE_URL
MARKREEL_STORE=inmemory

# Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Database
DATABASE_URL=postgresql://markreel:markreel@postgres:5432/markreel

# Redis
REDIS_URL=redis://redis:6379

# S3 (MinIO)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=markreel
S3_SECRET_KEY=markreel_secret
S3_BUCKET_ORIGINAL=markreel-original
S3_BUCKET_DERIVED=markreel-derived
S3_BUCKET_ATTACHMENTS=markreel-attachments

# Media processing
FFMPEG_THREADS=2
HLS_SEGMENT_SECONDS=4
HLS_PLAYLIST_TYPE=vody
