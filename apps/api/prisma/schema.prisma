generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  owner
  editor
  commenter
  viewer
}

enum OrganizationRole {
  owner
  admin
  member
}

enum PermissionSubjectType {
  creator
  organization
  invited_user
  public
}

enum ProjectPermission {
  manage
  upload
  view
}

enum MediaPermission {
  manage
  annotate
  view
}

enum UserGlobalRole {
  admin
  user
}

enum MediaProcessingStatus {
  uploaded
  queued
  processing
  ready
  failed
}

enum ReviewStatus {
  open
  needs_changes
  approved
}

enum AnnotationType {
  pin
  rect
  text
}

enum SharePermission {
  view
  comment
  annotate
}

enum ShareAudience {
  anyone
  authenticated
}

enum AttachmentKind {
  image
}

enum QuotaScopeType {
  user
  project
}

model User {
  id                String         @id @default(cuid())
  username          String         @unique
  passwordHash      String
  displayName       String?
  avatarObjectKey   String?
  avatarContentType String?
  avatarPreset      String?
  globalRole        UserGlobalRole @default(user)
  sessionVersion    Int            @default(1)
  lastLoginAt       DateTime?
  disabledAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  memberships          ProjectMember[]
  organizationMemberships OrganizationMember[]
  projects             Project[]        @relation("ProjectOwner")
  createdOrganizations Organization[]   @relation("OrganizationCreator")
  createdMedia         Media[]          @relation("MediaCreator")
  annotations          Annotation[]     @relation("AnnotationAuthor")
  completedAnnotations Annotation[]     @relation("AnnotationCompleter")
  mediaRatings         MediaRating[]
  auditLogs            AuditLog[]
  shareLinks           ShareLink[]
  projectPermissionGrants ProjectPermissionGrant[]
  mediaPermissionGrants   MediaPermissionGrant[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  createdBy User                 @relation("OrganizationCreator", fields: [createdById], references: [id])
  members   OrganizationMember[]
  projects  Project[]
}

model OrganizationMember {
  organizationId String
  userId         String
  role           OrganizationRole @default(member)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([organizationId, userId])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  organizationId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  organization Organization?  @relation(fields: [organizationId], references: [id])
  members     ProjectMember[]
  permissionGrants ProjectPermissionGrant[]
  folders     ProjectFolder[]
  media       Media[]
  shareLinks  ShareLink[]
  series      MediaSeries[]
  annotations Annotation[]
}

model ProjectPermissionGrant {
  id             String                @id @default(cuid())
  projectId      String
  subjectType    PermissionSubjectType
  subjectKey     String                @default("")
  subjectUserId  String?
  permission     ProjectPermission
  createdAt      DateTime              @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subjectUser User? @relation(fields: [subjectUserId], references: [id])

  @@unique([projectId, subjectType, subjectKey, permission])
}

model ProjectFolder {
  id        String   @id @default(cuid())
  projectId String
  parentId  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  project   Project        @relation(fields: [projectId], references: [id])
  parent    ProjectFolder? @relation("ProjectFolderChildren", fields: [parentId], references: [id])
  children  ProjectFolder[] @relation("ProjectFolderChildren")
  media     Media[]
}

model MediaSeries {
  id        String   @id @default(cuid())
  projectId String
  title     String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id])
  media    Media[]
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectRole
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
}

model Media {
  id           String                @id @default(cuid())
  projectId    String
  creatorId    String?
  folderId     String?
  title        String
  seriesId     String?
  versionIndex Int                   @default(1)
  status       MediaProcessingStatus @default(uploaded)
  reviewStatus ReviewStatus          @default(open)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?

  project     Project        @relation(fields: [projectId], references: [id])
  creator     User?          @relation("MediaCreator", fields: [creatorId], references: [id])
  folder      ProjectFolder? @relation(fields: [folderId], references: [id])
  series      MediaSeries?   @relation(fields: [seriesId], references: [id])
  files       MediaFile[]
  annotations Annotation[]
  ratings     MediaRating[]
  shareLinks  ShareLink[]
  permissionGrants MediaPermissionGrant[]
}

model MediaPermissionGrant {
  id             String                @id @default(cuid())
  mediaId        String
  subjectType    PermissionSubjectType
  subjectKey     String                @default("")
  subjectUserId  String?
  permission     MediaPermission
  createdAt      DateTime              @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  subjectUser User? @relation(fields: [subjectUserId], references: [id])

  @@unique([mediaId, subjectType, subjectKey, permission])
}

model MediaFile {
  id                String   @id @default(cuid())
  mediaId           String
  originalObjectKey String
  derivedPrefix     String?
  mode              String   // original|compress (MVP)
  durationMs        Int?
  width             Int?
  height            Int?
  sizeBytes         Int?
  bitrateKbps       Int?
  frameCount        Int?
  createdAt         DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id])

  @@unique([mediaId, originalObjectKey])
}

model Annotation {
  id            String         @id @default(cuid())
  projectId     String
  mediaId       String
  authorId      String
  parentId      String?
  timestampMs   Int
  type          AnnotationType
  rect          Json?
  body          String
  color         String?
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  project     Project      @relation(fields: [projectId], references: [id])
  media       Media        @relation(fields: [mediaId], references: [id])
  author      User         @relation("AnnotationAuthor", fields: [authorId], references: [id])
  parent      Annotation?  @relation("AnnotationReplies", fields: [parentId], references: [id])
  replies     Annotation[] @relation("AnnotationReplies")
  completedBy User?        @relation("AnnotationCompleter", fields: [completedById], references: [id])
  attachments Attachment[]
}

model MediaRating {
  id        String   @id @default(cuid())
  mediaId    String
  userId     String
  value      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  media Media @relation(fields: [mediaId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([mediaId, userId])
}

model Attachment {
  id          String         @id @default(cuid())
  annotationId String
  kind        AttachmentKind
  objectKey   String
  mimeType    String?
  width       Int?
  height      Int?
  createdAt   DateTime       @default(now())

  annotation Annotation @relation(fields: [annotationId], references: [id])
}

model ShareLink {
  id           String                @id @default(cuid())
  tokenHash    String                @unique
  projectId    String?
  mediaId      String?
  createdById  String?
  label        String?
  audience     ShareAudience         @default(anyone)
  passwordHash String?
  maxUses      Int?
  useCount     Int                   @default(0)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime              @default(now())

  project     Project?              @relation(fields: [projectId], references: [id])
  media       Media?                @relation(fields: [mediaId], references: [id])
  createdBy   User?                 @relation(fields: [createdById], references: [id])
  permissions ShareLinkPermission[]
}

model ShareLinkPermission {
  id          String          @id @default(cuid())
  shareLinkId String
  permission  SharePermission

  shareLink ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@unique([shareLinkId, permission])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorUserId String?
  action    String
  entityType String
  entityId  String
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id])
}

model Quota {
  id         String         @id @default(cuid())
  scopeType  QuotaScopeType
  scopeId    String
  maxBytes   BigInt
  usedBytes  BigInt @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([scopeType, scopeId])
}
